// Prisma Schema for MetalHub Marketplace
// PostgreSQL Database

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "auth"]
}

// ============================================
// 1. USERS (Authentication Core)
// ============================================
model User {
  id            String   @id @default(uuid())
  email         String?  @unique
  phone         String?  @unique
  passwordHash  String?  @map("password_hash")
  role          UserRole @default(BUYER)
  emailVerified Boolean  @default(false) @map("email_verified")
  phoneVerified Boolean  @default(false) @map("phone_verified")
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  profile       Profile?
  memberships   Membership[]
  listings      Listing[] @relation("SellerListings")
  chatsAsBuyer  Chat[] @relation("BuyerChats")
  chatsAsSeller Chat[] @relation("SellerChats")
  messages      Message[]
  payments       Payment[]
  loginActivities LoginActivity[]
  adminLogs     AdminLog[]
  sentOffers     Offer[] @relation("BuyerOffers")
  inquiries      Inquiry[]
  supplierProfile Supplier?

  // Ops Relations
  opsUserRoles    OpsUserRole[]
  grantedRoles    OpsUserRole[]   @relation("GrantedRoles")
  assignedLeads   Lead[]          @relation("AssignedLeads")
  leadActivities  LeadActivity[]
  auditLogs       AuditLog[]
  notifications   Notification[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([status])
  @@map("users")
  @@schema("public")
}

enum UserRole {
  BUYER
  SELLER
  ADMIN

  @@schema("public")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED

  @@schema("public")
}

// ============================================
// 2. PROFILES (User Details)
// ============================================
model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  fullName    String?  @map("full_name")
  companyName String?  @map("company_name")
  location    Json?    // { city, state, country }
  bio         String?
  logoUrl     String?  @map("logo_url")
  kycStatus   KycStatus @default(PENDING) @map("kyc_status")
  responseTime Int?     @map("response_time") // Added to track average response in minutes
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
  @@schema("public")
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED

  @@schema("public")
}

// ============================================
// 3. MEMBERSHIPS (Plans & Access Control)
// ============================================
model Membership {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  plan      MembershipPlan
  startDate DateTime       @default(now()) @map("start_date")
  endDate   DateTime?      @map("end_date")
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([plan])
  @@map("memberships")
  @@schema("public")
}

enum MembershipPlan {
  FREE
  SILVER
  GOLD

  @@schema("public")
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED

  @@schema("public")
}

// ============================================
// 4. LISTINGS (Metal Products)
// ============================================
model Listing {
  id           String        @id @default(uuid())
  sellerId     String        @map("seller_id")
  title        String
  description  String
  metalType    MetalType     @map("metal_type")
  listingRole  ListingRole   @default(SUPPLIER) @map("listing_role")
  listingType  ListingType   @default(MEMBERS) @map("listing_type")
  premiumStatus MembershipPlan @default(FREE) @map("premium_status")
  country      String?       @map("country")
  industries   String[]      @default([]) @map("industries")
  capabilities String[]      @default([]) @map("capabilities")
  metals       String[]      @default([]) @map("metals")
  grade        String?
  price        Decimal       @db.Decimal(12, 2)
  isNegotiable Boolean       @default(false) @map("is_negotiable")
  quantity     Decimal       @db.Decimal(12, 2)
  unit         String        @default("MT")
  location     Json          // { city, state, country }
  status       ListingStatus @default(PENDING)
  isFeatured   Boolean       @default(false) @map("is_featured")
  viewsCount   Int           @default(0) @map("views_count")
  featuredUntil DateTime?    @map("featured_until")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  expiresAt    DateTime?     @map("expires_at")

  // Relations
  seller       User          @relation("SellerListings", fields: [sellerId], references: [id], onDelete: Cascade)
  images       ListingImage[]
  chats        Chat[]
  offers       Offer[]

  @@index([sellerId])
  @@index([metalType])
  @@index([listingRole])
  @@index([listingType])
  @@index([premiumStatus])
  @@index([country])
  @@index([industries], type: Gin)
  @@index([capabilities], type: Gin)
  @@index([metals], type: Gin)
  @@index([status])
  @@index([isFeatured])
  @@index([createdAt])
  @@map("listings")
  @@schema("public")
}

enum ListingRole {
  BUYER
  SUPPLIER

  @@schema("public")
}

enum ListingType {
  BUY_LEADS
  MEMBERS

  @@schema("public")
}

enum MetalType {
  STEEL
  IRON
  ALUMINIUM
  COPPER
  BRASS
  STAINLESS_STEEL
  OTHER

  @@schema("public")
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
  EXPIRED

  @@schema("public")
}

// ============================================
// 5. LISTING_IMAGES (Metadata Only)
// ============================================
model ListingImage {
  id         String   @id @default(uuid())
  listingId  String   @map("listing_id")
  imageUrl   String   @map("image_url")
  mlVerified Boolean  @default(false) @map("ml_verified")
  mlScore    Float?   @map("ml_score")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
  @@schema("public")
}

// ============================================
// 6. CHATS (Buyer ↔ Seller Conversations)
// ============================================
model Chat {
  id            String    @id @default(uuid())
  listingId     String    @map("listing_id")
  buyerId       String    @map("buyer_id")
  sellerId      String    @map("seller_id")
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User    @relation("BuyerChats", fields: [buyerId], references: [id], onDelete: Cascade)
  seller  User    @relation("SellerChats", fields: [sellerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([listingId, buyerId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@map("chats")
  @@schema("public")
}

// ============================================
// 7. MESSAGES (Chat Messages)
// ============================================
model Message {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id")
  senderId  String   @map("sender_id")
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
  @@schema("public")
}

// ============================================
// 8. OFFERS (Price Negotiation)
// ============================================
model Offer {
  id        String      @id @default(uuid())
  listingId String      @map("listing_id")
  buyerId   String      @map("buyer_id")
  offerPrice Decimal    @db.Decimal(12, 2) @map("offer_price")
  status    OfferStatus @default(PENDING)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User    @relation("BuyerOffers", fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([buyerId])
  @@index([status])
  @@map("offers")
  @@schema("public")
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  EXPIRED

  @@schema("public")
}

// ============================================
// 9. PAYMENTS (Razorpay Transactions)
// ============================================
model Payment {
  id               String        @id @default(uuid())
  userId           String        @map("user_id")
  razorpayOrderId String        @unique @map("razorpay_order_id")
  razorpayPaymentId String?      @unique @map("razorpay_payment_id")
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("INR")
  status           PaymentStatus @default(CREATED)
  plan             MembershipPlan?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([razorpayOrderId])
  @@index([status])
  @@map("payments")
  @@schema("public")
}

enum PaymentStatus {
  CREATED
  SUCCESS
  FAILED
  REFUNDED

  @@schema("public")
}

// ============================================
// 10. RAZORPAY_EVENTS (Webhook Logs)
// ============================================
model RazorpayEvent {
  id        String   @id @default(uuid())
  eventType String   @map("event_type")
  payload   Json
  receivedAt DateTime @default(now()) @map("received_at")

  @@index([eventType])
  @@index([receivedAt])
  @@map("razorpay_events")
  @@schema("public")
}

// ============================================
// 11. LOGIN_ACTIVITY (Security Tracking)
// ============================================
model LoginActivity {
  id              String   @id @default(uuid())
  userId          String?  @map("user_id")
  ipAddress       String   @map("ip_address")
  deviceFingerprint String? @map("device_fingerprint")
  userAgent       String?  @map("user_agent")
  success         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ipAddress])
  @@index([deviceFingerprint])
  @@index([createdAt])
  @@map("login_activity")
  @@schema("public")
}

// ============================================
// 12. ADMIN_LOGS (Audit Trail)
// ============================================
model AdminLog {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  action    String
  targetId  String?  @map("target_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_logs")
  @@schema("public")
}

// ============================================
// 13. BANNERS (Homepage Hero Carousel)
// ============================================
model Banner {
  id         String   @id @default(uuid())
  title      String
  subtitle   String
  imageUrl   String   @map("image_url")
  ctaText    String   @map("cta_text")
  ctaLink    String   @map("cta_link")
  isActive   Boolean  @default(true) @map("is_active")
  orderIndex Int      @default(0) @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([isActive, orderIndex])
  @@map("banners")
  @@schema("public")
}

// ============================================
// 14. CAPABILITIES (Industrial Category Hub)
// ============================================
model Capability {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  imageUrl     String   @map("image_url")
  description  String
  heroImageUrl String?  @map("hero_image_url")
  heroTitle    String?  @map("hero_title")
  heroSubtitle String?  @map("hero_subtitle")
  isActive     Boolean  @default(true) @map("is_active")
  orderIndex   Int      @default(0) @map("order_index")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  inquiries        Inquiry[]
  supplierProducts SupplierProduct[]
  supplierLinks    SupplierCapability[]
  productLinks     ProductCapability[]
  requirementLinks RequirementCapability[]

  @@index([isActive, orderIndex])
  @@map("capabilities")
  @@schema("public")
}

model Industry {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  suppliers SupplierIndustry[]
  inquiries Inquiry[]

  @@index([name])
  @@map("industries")
  @@schema("public")
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  parentId  String?   @map("parent_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  parent      Category?        @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]       @relation("CategoryHierarchy")
  products    SupplierProduct[]
  inquiries   Inquiry[]

  @@index([name])
  @@index([parentId])
  @@map("categories")
  @@schema("public")
}

// ============================================
// 15. INQUIRIES (Buyer Requirements)
// ============================================
model Inquiry {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  capabilityId String?       @map("capability_id")
  industryId   String?       @map("industry_id")
  categoryId   String?       @map("category_id")
  category     String
  productName  String        @map("product_name")
  description  String
  material     String?
  keywords     String[]      @default([])
  applications String[]      @default([])
  specDocUrls  String[]      @default([]) @map("spec_doc_urls")
  quantity     String
  budget       Decimal?      @db.Decimal(12, 2)
  budgetRange  String?       @map("budget_range")
  location     String
  urgency      String        @default("MEDIUM")
  viewsCount   Int           @default(0) @map("views_count")
  quoteCount   Int           @default(0) @map("quote_count")
  status       InquiryStatus @default(OPEN)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  buyer               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  capability          Capability?             @relation(fields: [capabilityId], references: [id], onDelete: SetNull)
  industry            Industry?               @relation(fields: [industryId], references: [id], onDelete: SetNull)
  categoryRef         Category?               @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  capabilityMappings  RequirementCapability[]

  @@index([userId])
  @@index([capabilityId])
  @@index([industryId])
  @@index([categoryId])
  @@index([category])
  @@index([location])
  @@index([status])
  @@index([createdAt])
  @@index([keywords], type: Gin)
  @@index([applications], type: Gin)
  @@map("inquiries")
  @@schema("public")
}

enum InquiryStatus {
  OPEN
  PAUSED
  CLOSED

  @@schema("public")
}

// ============================================
// 16. SUPPLIERS (Verified Marketplace Sellers)
// ============================================
model Supplier {
  id          String   @id @default(uuid())
  userId      String?  @unique @map("user_id")
  companyName String   @map("company_name")
  tagline     String?
  description String
  location    String
  isVerified  Boolean  @default(false) @map("is_verified")
  isoCertified Boolean @default(false) @map("iso_certified")
  exportReady  Boolean @default(false) @map("export_ready")
  responseTimeMinutes Int @default(120) @map("response_time_minutes")
  completionRate Float @default(78) @map("completion_rate")
  rating      Decimal  @default(4.2) @db.Decimal(2, 1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner            User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  products         SupplierProduct[]
  capabilityLinks  SupplierCapability[]
  industryLinks    SupplierIndustry[]

  @@index([isVerified])
  @@index([location])
  @@index([createdAt])
  @@map("suppliers")
  @@schema("public")
}

// ============================================
// 17. SUPPLIER_PRODUCTS (Supplier Catalog)
// ============================================
model SupplierProduct {
  id           String   @id @default(uuid())
  supplierId   String   @map("supplier_id")
  capabilityId String?  @map("capability_id")
  categoryId   String?  @map("category_id")
  category     String
  productName  String   @map("product_name")
  material     String?
  industries   String[] @default([])
  applications String[] @default([])
  keywords     String[] @default([])
  priceRange   String   @map("price_range")
  moq          String
  productionCapacity String @map("production_capacity")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  supplier         Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  capability       Capability?         @relation(fields: [capabilityId], references: [id], onDelete: SetNull)
  categoryRef      Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  capabilityLinks  ProductCapability[]

  @@index([supplierId])
  @@index([capabilityId])
  @@index([categoryId])
  @@index([category])
  @@index([createdAt])
  @@index([keywords], type: Gin)
  @@index([industries], type: Gin)
  @@index([applications], type: Gin)
  @@map("supplier_products")
  @@schema("public")
}

model SupplierCapability {
  supplierId   String @map("supplier_id")
  capabilityId String @map("capability_id")
  createdAt    DateTime @default(now()) @map("created_at")

  supplier   Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([supplierId, capabilityId])
  @@index([capabilityId])
  @@map("supplier_capabilities")
  @@schema("public")
}

model SupplierIndustry {
  supplierId String @map("supplier_id")
  industryId String @map("industry_id")
  createdAt  DateTime @default(now()) @map("created_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  industry Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@id([supplierId, industryId])
  @@index([industryId])
  @@map("supplier_industries")
  @@schema("public")
}

model ProductCapability {
  productId    String @map("product_id")
  capabilityId String @map("capability_id")
  createdAt    DateTime @default(now()) @map("created_at")

  product    SupplierProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  capability Capability      @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([productId, capabilityId])
  @@index([capabilityId])
  @@map("product_capabilities")
  @@schema("public")
}

model RequirementCapability {
  requirementId String @map("requirement_id")
  capabilityId  String @map("capability_id")
  createdAt     DateTime @default(now()) @map("created_at")

  requirement Inquiry    @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  capability  Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([requirementId, capabilityId])
  @@index([capabilityId])
  @@map("requirement_capabilities")
  @@schema("public")
}

// ============================================
// 18. OPS ROLES (RBAC - Role-Based Access Control)
// ============================================
model OpsRole {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  isSystem    Boolean  @default(false)  @map("is_system")
  createdAt   DateTime @default(now())  @map("created_at")
  updatedAt   DateTime @updatedAt       @map("updated_at")

  permissions OpsRolePermission[]
  users       OpsUserRole[]

  @@map("ops_roles")
  @@schema("public")
}

model OpsPermission {
  id          String   @id @default(uuid())
  code        String   @unique
  module      String
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())  @map("created_at")

  roles OpsRolePermission[]

  @@index([module])
  @@index([resource])
  @@map("ops_permissions")
  @@schema("public")
}

model OpsRolePermission {
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       OpsRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission OpsPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("ops_role_permissions")
  @@schema("public")
}

model OpsUserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  grantedBy String   @map("granted_by")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    OpsRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  granter User    @relation("GrantedRoles", fields: [grantedBy], references: [id])

  @@id([userId, roleId])
  @@map("ops_user_roles")
  @@schema("public")
}

// ============================================
// 19. CRM LEADS (Sales Pipeline)
// ============================================
model Lead {
  id           String     @id @default(uuid())
  companyName  String     @map("company_name")
  contactName  String     @map("contact_name")
  contactEmail String?    @map("contact_email")
  contactPhone String?    @map("contact_phone")
  source       String     @default("MANUAL")
  stage        LeadStage  @default(NEW)
  dealValue    Decimal?   @db.Decimal(12, 2) @map("deal_value")
  probability  Int?       @default(0)
  assignedTo   String?    @map("assigned_to")
  notes        String?
  nextFollowUp DateTime?  @map("next_follow_up")
  lostReason   String?    @map("lost_reason")
  convertedAt  DateTime?  @map("converted_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  assignee   User?          @relation("AssignedLeads", fields: [assignedTo], references: [id])
  activities LeadActivity[]

  @@index([stage])
  @@index([assignedTo])
  @@index([source])
  @@index([createdAt])
  @@map("leads")
  @@schema("public")
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATION
  CONVERTED
  LOST

  @@schema("public")
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  userId    String   @map("user_id")
  type      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([userId])
  @@index([createdAt])
  @@map("lead_activities")
  @@schema("public")
}

// ============================================
// 20. ENHANCED AUDIT LOG
// ============================================
model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([resourceId])
  @@index([createdAt])
  @@map("audit_logs")
  @@schema("public")
}

// ============================================
// 21. NOTIFICATION SYSTEM
// ============================================
model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  priority  String   @default("normal")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([priority])
  @@index([createdAt])
  @@map("notifications")
  @@schema("public")
}
