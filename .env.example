# CustomTolerance — Environment Variables (Next.js + Supabase)
# Copy to .env.local and fill in values.

# ── Supabase (required) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URLs ──
NEXT_PUBLIC_SITE_URL=https://customtolerance.com
NEXT_PUBLIC_APP_URL=https://customtolerance.com

# ── Email (Resend) ──
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@customtolerance.com
EMAIL_FROM_NAME=CustomTolerance

# ── OTP / Security ──
OTP_HASH_SALT=change-me-in-production
OTP_EXPIRY_MINUTES=10
AUTH_DEBUG=false

# Signup email OTP uses Supabase Auth (not custom OTP generation).
# Configure Supabase Dashboard → Email Templates → Confirm signup to use {{ .Token }}
# See docs/email-otp-verification.md for full setup.

# ── Trust / Feature Flags ──
NEXT_PUBLIC_DEVELOPMENT_TRUST_MODE=true

# ── Database (seeds & scripts only — app runtime uses Supabase client) ──
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Payments (optional — enable when launching Razorpay) ──
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ── DEPRECATED (NestJS backend removed — do not set) ──
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_BACKEND_URL=
# JWT_SECRET=
# REDIS_HOST=

# ── Procurement platform (Phase 6 — NOT wired yet; confirm before enabling) ──
# GST verification (MasterIndia / ClearTax / SignDesk)
# GST_API_PROVIDER=masterindia
# GST_API_KEY=
# GST_API_BASE_URL=

# WhatsApp Business (Gupshup OR Twilio)
# WHATSAPP_PROVIDER=gupshup
# GUPSHUP_API_KEY=
# GUPSHUP_APP_NAME=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=

# Typesense search
# TYPESENSE_HOST=
# TYPESENSE_PORT=443
# TYPESENSE_PROTOCOL=https
# TYPESENSE_API_KEY=
# NEXT_PUBLIC_TYPESENSE_SEARCH_ONLY_KEY=

# Ably realtime messaging
# ABLY_API_KEY=
# NEXT_PUBLIC_ABLY_CLIENT_KEY=

# Cloudflare R2 (optional; app uses Supabase Storage by default for RFQ files)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# Feature toggles (keep false until external services are configured)
# NEXT_PUBLIC_ENABLE_TYPESENSE=false
# NEXT_PUBLIC_ENABLE_WHATSAPP=false
# NEXT_PUBLIC_ENABLE_ABLY=false
# NEXT_PUBLIC_ENABLE_GST_API=false
# NEXT_PUBLIC_ENABLE_R2_UPLOADS=false
